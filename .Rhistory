data_merged <- data_merged %>%
mutate(bonus = case_when(
PRESENCE < 4 ~ 0,
PRESENCE >= 4 & PRESENCE <= 5 ~ 1,
PRESENCE == 6 ~ 2,
PRESENCE > 6 ~ 3
))
table(data_merged$bonus)
data_merged <- data_merged %>%
mutate(bonus = case_when(
PRESENCE < 4 ~ 0,
PRESENCE >= 4 & PRESENCE <= 5 ~ 1,
PRESENCE >= 6 & PRESENCE <= 7 ~ 2,
PRESENCE > 7 ~ 3
))
table(data_merged$bonus)
data_merged$note_CC2_finale <- data_merged$`Note CC2`+data_merged$bonus
